<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechCorp Solutions - Enterprise Software</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #ffffff;
            color: #1f2937;
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
        }

        /* Navigation */
        nav {
            background: #ffffff;
            border-bottom: 1px solid #e5e7eb;
            padding: 1rem 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        nav ul {
            list-style: none;
            display: flex;
            gap: 2rem;
            max-width: 1200px;
            margin: 0 auto;
            align-items: center;
        }

        nav a {
            color: #1f2937;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s;
        }

        nav a:hover {
            color: #2563eb;
        }

        .logo {
            font-weight: 700;
            font-size: 1.25rem;
            color: #2563eb;
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
            color: white;
            padding: 6rem 2rem;
            text-align: center;
        }

        .hero h1 {
            font-family: 'Poppins', sans-serif;
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .hero p {
            font-size: 1.25rem;
            margin-bottom: 2rem;
            opacity: 0.95;
        }

        /* Main Container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* Content Sections */
        section {
            padding: 3rem 0;
        }

        .section-title {
            font-family: 'Poppins', sans-serif;
            font-size: 2rem;
            margin-bottom: 1.5rem;
            color: #1f2937;
        }

        .feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin: 2rem 0;
        }

        .feature-card {
            background: #f9fafb;
            padding: 2rem;
            border-radius: 8px;
            border: 1px solid #e5e7eb;
            transition: all 0.3s;
        }

        .feature-card:hover {
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            border-color: #2563eb;
        }

        .feature-card h3 {
            color: #2563eb;
            margin-bottom: 0.5rem;
            font-family: 'Poppins', sans-serif;
        }

        .feature-card p {
            color: #6b7280;
            font-size: 0.95rem;
        }

        /* Info Box */
        .info-box {
            background: #f0f9ff;
            border-left: 4px solid #2563eb;
            padding: 1.5rem;
            margin: 2rem 0;
            border-radius: 4px;
        }

        .info-box h4 {
            color: #2563eb;
            margin-bottom: 0.5rem;
            font-family: 'Poppins', sans-serif;
        }

        .info-box p {
            color: #1e40af;
        }

        /* Code Block */
        .code-block {
            background: #1f2937;
            color: #e5e7eb;
            padding: 1.5rem;
            border-radius: 8px;
            overflow-x: auto;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.9rem;
            margin: 1rem 0;
        }

        /* Buttons */
        button, .button {
            background: #2563eb;
            color: white;
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
            text-decoration: none;
            display: inline-block;
        }

        button:hover, .button:hover {
            background: #1e40af;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(37, 99, 235, 0.3);
        }

        .button-group {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        /* Footer */
        footer {
            background: #1f2937;
            color: white;
            text-align: center;
            padding: 2rem;
            margin-top: 3rem;
        }

        footer p {
            margin: 0.5rem 0;
            opacity: 0.8;
        }

        code {
            background: rgba(0, 0, 0, 0.5);
            color: #6b7280;
            padding: 2px 6px;
            border-radius: 2px;
            font-family: monospace;
        }

        .highlight {
            color: #2563eb;
            font-weight: 600;
        }

        .text-muted {
            color: #9ca3af;
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2rem;
            }

            nav ul {
                gap: 1rem;
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <ul>
            <li class="logo">TechCorp</li>
            <li><a href="#about">About</a></li>
            <li><a href="#solutions">Solutions</a></li>
            <li><a href="#features">Features</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <h1>Enterprise Software Solutions</h1>
            <p>Secure, scalable, and reliable technology for your business</p>
        </div>
    </section>

    <!-- About Section -->
    <section id="about">
        <div class="container">
            <h2 class="section-title">About TechCorp</h2>
            <p style="font-size: 1.1rem; color: #4b5563; margin-bottom: 1rem;">
                TechCorp is a global leader in digital innovation and enterprise solutions. We empower organizations to succeed in an increasingly digital world 
                by providing comprehensive technology platforms and expert consulting services. Our mission is to make technology accessible, reliable, and transformative 
                for businesses of all sizes.
            </p>
            <div class="feature-grid">
                <div class="feature-card">
                    <h3>🌍 Global Presence</h3>
                    <p>Serving clients in 45+ countries with local expertise and global resources. Our distributed teams ensure round-the-clock support.</p>
                </div>
                <div class="feature-card">
                    <h3>💡 Innovation Hub</h3>
                    <p>Continuous R&D investment keeps us at the forefront of technology. We develop solutions that anticipate market needs.</p>
                </div>
                <div class="feature-card">
                    <h3>🤝 Partner-Focused</h3>
                    <p>We believe in long-term partnerships. Your success is our success, and we're committed to growing together.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Solutions Section -->
    <section id="solutions" style="background: #f9fafb;">
        <div class="container">
            <h2 class="section-title">Our Solutions</h2>
            <div class="feature-grid">
                <div class="feature-card">
                    <h3>Cloud Services</h3>
                    <p>Leverage the power of distributed cloud computing to scale your business. Deploy applications globally with reliability and performance.</p>
                </div>
                <div class="feature-card">
                    <h3>Business Intelligence</h3>
                    <p>Transform your data into actionable insights. Our analytics platform helps you make informed decisions and drive growth.</p>
                </div>
                <div class="feature-card">
                    <h3>Digital Transformation</h3>
                    <p>Modernize your operations with cutting-edge technology. We guide you through every step of your digital journey.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features">
        <div class="container">
            <h2 class="section-title">Why Choose Us</h2>
            <div class="info-box">
                <h4>✓ Industry Expertise</h4>
                <p>With over 15 years of experience, we've served more than 500 companies across finance, healthcare, retail, and manufacturing sectors.</p>
            </div>
            <div class="info-box">
                <h4>✓ Award-Winning Support</h4>
                <p>Our dedicated support team is available 24/7 to ensure your operations run smoothly. Average response time: under 15 minutes.</p>
            </div>
            <div class="info-box">
                <h4>✓ Proven Results</h4>
                <p>Our clients report an average 40% increase in efficiency and 30% reduction in operational costs within the first year of implementation.</p>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section style="background: #f0f9ff;">
        <div class="container">
            <h2 class="section-title">What Our Clients Say</h2>
            <div class="feature-grid">
                <div class="feature-card" style="background: white;">
                    <p style="margin-bottom: 1rem; font-style: italic;">"TechCorp helped us transform our entire business process. The results exceeded our expectations!"</p>
                    <p style="font-weight: 600; color: #2563eb;">Jane Smith, CEO of Retail Solutions</p>
                </div>
                <div class="feature-card" style="background: white;">
                    <p style="margin-bottom: 1rem; font-style: italic;">"Best decision we made. Their team is knowledgeable, professional, and truly care about our success."</p>
                    <p style="font-weight: 600; color: #2563eb;">Michael Chen, Operations Director</p>
                </div>
                <div class="feature-card" style="background: white;">
                    <p style="margin-bottom: 1rem; font-style: italic;">"Exceptional service and support. They made the transition seamless and painless for our entire organization."</p>
                    <p style="font-weight: 600; color: #2563eb;">Sarah Johnson, VP of Finance</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact">
        <div class="container">
            <h2 class="section-title">Ready to Drive Your Success?</h2>
            <p style="font-size: 1.1rem; color: #6b7280; margin-bottom: 2rem;">
                Schedule a consultation with our team today and discover how TechCorp can transform your business.
            </p>
            <div class="button-group">
                <button>Contact Sales</button>
                <button style="background: white; color: #2563eb; border: 2px solid #2563eb;">View Pricing</button>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <p>&copy; 2024 TechCorp Solutions. All rights reserved.</p>
            <p>
                <a href="#" style="color: #93c5fd; text-decoration: none; margin: 0 10px;">Privacy Policy</a> | 
                <a href="#" style="color: #93c5fd; text-decoration: none; margin: 0 10px;">Terms of Service</a> | 
                <a href="#" style="color: #93c5fd; text-decoration: none; margin: 0 10px;">Contact Us</a>
            </p>
        </div>
    </footer>

    <script>
        // Smooth scrolling for navigation links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                }
            });
        });
    </script>
</body>
</html>
